---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mathias Kron — Psycho-Thriller aus der Ich-Perspektive',
  description = 'Wer einem Serienmörder im Kopf sitzt, lernt seine Maske besser kennen als seine Familie. Der Nachbar aus Harmony Creek — eine 52-wöchige Saga aus dem Inneren einer pathologischen Psyche. In der Schule von Patricia Highsmith und Thomas Harris. Bald erhältlich.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://mathiaskron.fuenfgroschenverlag.com');
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#100e15" />
  </head>
  <body>
    <slot />
  </body>
</html>
